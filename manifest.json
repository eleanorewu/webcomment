{
  "manifest_version": 3,
  "name": "WebComment 標注工具",
  "description": "在任何網站或 localhost 上直接標注意見。",
  "version": "0.1.0",
  "action": {
    "default_title": "WebComment 標注工具",
    "default_popup": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "permissions": ["activeTab", "storage", "scripting", "tabs"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/shared/store.js", "src/content/content-script.js"],
      "css": ["src/content/content-script.css"],
      "run_at": "document_idle"
    }
  ]
}
